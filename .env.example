# JWT bearer token (without the "Bearer " prefix)
JWT_TOKEN=your_jwt_token_here

# The user UUID used in the endpoint path
USER_UUID=your_user_uuid_here

# How many requests to run in parallel (default: 5)
CONCURRENCY=5

# How many times to run each combination with fresh random inputs (default: 1)
# Each "run" fires the same payload FLAKINESS_RUNS times.
RUNS_PER_COMBO=1

# How many times to fire the SAME payload per combination to measure flakiness (default: 3)
# Higher = more confidence in flak_label (stable / flaky / deterministic).
# Also controls how many times each isolation variant fires for failing combos.
FLAKINESS_RUNS=3

# ─── Tag combinations mode ────────────────────────────────────────────────────
# Set MODE=tags to sweep all non-empty tag subsets against a fixed taxonomy combo
# instead of sweeping all taxonomy combos with random tags.
# Default: taxonomy
#MODE=tags

# Maximum tag-subset size to test in tags mode.
# 1 = single-tag sweep (9 combos), 2 = single + pairs (45 combos), 9 = all 511 subsets.
# Default: 9
#MAX_TAG_SIZE=2

# The taxonomy combo used as the fixed context in tags mode.
# If unset, defaults to the first combo in the taxonomy (Arts & Culture › Arts Education).
# TAG_MODE_ORG_TYPE and TAG_MODE_ACTIVITY must both be set, or both left unset.
#TAG_MODE_ORG_TYPE=Sports & Athletics
#TAG_MODE_ACTIVITY=Basketball
#TAG_MODE_AFFILIATION=High School
# ─────────────────────────────────────────────────────────────────────────────

# Per-category event and org names used when building test requests.
# Each category requires both EVENT_NAMES_[SLUG] and ORG_NAMES_[SLUG] — the tool will exit
# immediately on startup if any are missing or empty.
# 5 values per list; the last 2 in each set are intentionally ambiguous to probe model edge cases.

# Arts & Culture
EVENT_NAMES_ARTS=Spotlight Gala,Arts Showcase,Spring Performance,Our Big Event,Year-End Drive
ORG_NAMES_ARTS=Westfield Theatre Guild,Harmony Choir Boosters,Canvas Studio Collective,The Arts Group,Community Creative

# Associations, Clubs & Community
EVENT_NAMES_COMMUNITY=Neighborhood Drive,Community Impact Fund,Service Week,Local Support Campaign,Annual Giving Day
ORG_NAMES_COMMUNITY=Riverside Scouts Troop,City Parks Foundation,Heritage Alumni Society,Our Local Club,Community Group 42

# Education & Academics
EVENT_NAMES_EDUCATION=Academic Excellence Drive,PTA Spring Fund,Scholar Push,Fall Initiative,Back to School Campaign
ORG_NAMES_EDUCATION=Lincoln PTA,Northview FBLA Chapter,Westfield Student Council,The School Group,Learners United

# Health & Wellness
EVENT_NAMES_HEALTH=Wellness Walk,Research Support Drive,Family Care Fund,Our Cause Campaign,Health Awareness Week
ORG_NAMES_HEALTH=Sunrise Health Initiative,Hope Family Support Center,Red Cross Metro Chapter,The Wellness Org,Community Health Group

# Religious Organization
EVENT_NAMES_RELIGIOUS=Faith and Family Drive,Youth Retreat Fund,Ministry Support Campaign,Community Giving Day,Our Mission Push
ORG_NAMES_RELIGIOUS=Cornerstone Fellowship,Open Arms Ministry,Eastside Youth Group,The Faith Community,Local Congregation

# Sororities & Fraternities
EVENT_NAMES_GREEK=Greek Week Fundraiser,Chapter Excellence Drive,Alumni Reunion Fund,Our Chapter Campaign,Philanthropy Push
ORG_NAMES_GREEK=Lambda Xi Chapter,Sigma Pride Collective,Alpha Alliance Network,The Greek Council,Our Chapter

# Sports & Athletics
EVENT_NAMES_SPORTS=Season Kickoff Fund,Championship Sendoff,Tournament Travel Drive,Team Push 2026,Game Day Campaign
ORG_NAMES_SPORTS=Falcon Athletic Boosters,Summit Soccer Club,Northside Cheer Team,The Sports Group,Team United

# Other
EVENT_NAMES_OTHER=Community Drive,Annual Fund,Special Campaign,Year-End Push,Our Fundraiser
ORG_NAMES_OTHER=Helping Hands Group,The Community Org,Local Initiative,Together We Give,Our Team

# Personal (individual fundraising for themselves)
EVENT_NAMES_PERSONAL=Medical Bills Fund,Marathon Training Push,Study Abroad Dream,Recovery Support Drive,My Fresh Start
ORG_NAMES_PERSONAL=Sarah Johnson,Marcus Rivera,The Chen Family,A Friend in Need,Just Getting Started
