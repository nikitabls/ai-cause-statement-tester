# JWT bearer token (without the "Bearer " prefix)
JWT_TOKEN=your_jwt_token_here

# The user UUID used in the endpoint path
USER_UUID=your_user_uuid_here

# How many requests to run in parallel (default: 5)
CONCURRENCY=5

# How many times to run each combination with fresh random inputs (default: 1)
# Each "run" fires the same payload FLAKINESS_RUNS times.
RUNS_PER_COMBO=1

# How many times to fire the SAME payload per combination to measure flakiness (default: 3)
# Higher = more confidence in flak_label (stable / flaky / deterministic).
# Also controls how many times each isolation variant fires for failing combos.
FLAKINESS_RUNS=3

# Comma-separated list of fundraiser event names to pick from randomly.
EVENT_NAMES=Spring Fundraiser,Annual Drive,Fall Campaign,End-of-Year Gala,Community Bash

# Comma-separated list of organization names to pick from randomly.
ORG_NAMES=Lincoln High School,Riverside Community,Sunset Academy,Greenwood Booster Club,Maplewood Athletics
